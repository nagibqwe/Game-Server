<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper  PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN"  "http://ibatis.apache.org/dtd/ibatis-3-mapper.dtd">
<mapper namespace="soulAnimalForestFollow">
    <resultMap id="bean" type="com.game.db.bean.SoulAnimalForestFollowBean" >
        <result column="saf_configId" property="saf_configId" jdbcType="INTEGER" />
        <result column="followValue" property="followValue" jdbcType="LONGVARCHAR" />
    </resultMap>

    <select id="selectAll" resultMap="bean">
        select * from soulAnimalForestFollow
    </select>
	
    <insert id="insert" parameterType="com.game.db.bean.SoulAnimalForestFollowBean">
        insert into soulAnimalForestFollow (saf_configId,followValue) 
        values
        (
        #{saf_configId, jdbcType=INTEGER}, #{followValue, jdbcType=LONGVARCHAR}
        )
    </insert>
		
    <update id="update" parameterType="com.game.db.bean.SoulAnimalForestFollowBean">
        update soulAnimalForestFollow set  
        saf_configId = #{saf_configId,jdbcType=INTEGER },followValue = #{followValue,jdbcType=LONGVARCHAR }
        where
        saf_configId = #{saf_configId,jdbcType=INTEGER}
    </update>
    
    <delete id="delete" parameterType="Integer">
        delete from soulAnimalForestFollow where saf_configId = #{saf_configId,jdbcType=INTEGER}
    </delete>	
		
</mapper>

