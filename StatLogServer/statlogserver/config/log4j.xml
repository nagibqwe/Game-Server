<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">
<log4j:configuration
		xmlns:log4j="http://jakarta.apache.org/log4j/" debug="false">
	<appender name="CONSOLE"
			  class="org.apache.log4j.ConsoleAppender">
		<param name="Target" value="System.err" />
		<param name="Threshold" value="ALL" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%-d{yyyy-MM-dd HH:mm:ss SSS} (%F:%L) [%t:%r]-[%p] %m%n" />
		</layout>
	</appender>
	<appender name="error_appender"
			  class="org.apache.log4j.DailyRollingFileAppender">
		<param name="File"
			   value="logs/error.log" />
		<param name="Threshold" value="ALL" />
		<param name="DatePattern" value="'.'yyyy-MM-dd'.log'" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern"
				   value="%-d{yyyy-MM-dd HH:mm:ss SSS} (%F:%L) [%t:%r]-[%p] %m%n" />
		</layout>
	</appender>
	<logger name="error_logger" additivity="false">
		<level value="error" />
		<appender-ref ref="error_appender" />
	</logger>
	<root>
		<level value="info" />
		<appender-ref ref="error_appender" />
		<appender-ref ref="CONSOLE" />
	</root>
</log4j:configuration>
