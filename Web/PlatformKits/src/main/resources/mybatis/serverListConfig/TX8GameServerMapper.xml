<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kits.project.serverListConfig.x8server.mapper.TX8GameServerMapper">
    
    <resultMap type="TX8GameServer" id="TX8GameServerResult">
        <result property="svrId"    column="svr_id"    />
        <result property="svrName"    column="svr_name"    />
        <result property="gameId"    column="game_id"    />
        <result property="svrIp"    column="svr_ip"    />
        <result property="svrPort"    column="svr_port"    />
        <result property="svrPayCallback"    column="svr_pay_callback"    />
        <result property="svrExtconfig"    column="svr_extconfig"    />
        <result property="mapSvrId"    column="map_svr_id"    />
        <result property="updateTime"    column="update_time"    />
        <result property="createTime"    column="create_time"    />
        <result property="groupType"    column="group_type"    />
        <result property="areaId"    column="area_id"    />
        <result property="mergeStatus"    column="merge_status"    />
        <result property="createUser"    column="create_user"    />
        <result property="updateUser"    column="update_user"    />
        <result property="source"    column="source"    />
        <result property="mapAreaId"    column="map_area_id"    />
    </resultMap>

    <sql id="selectTX8GameServerVo">
        select svr_id, svr_name, game_id, svr_ip, svr_port, svr_pay_callback, svr_extconfig, map_svr_id, update_time, create_time, group_type, area_id, merge_status, create_user, update_user, source, map_area_id from t_x8_game_server
    </sql>

    <select id="selectTX8GameServerList" parameterType="TX8GameServer" resultMap="TX8GameServerResult">
        <include refid="selectTX8GameServerVo"/>
        <where>  
            <if test="svrName != null  and svrName != ''"> and svr_name like concat('%', #{svrName}, '%')</if>
            <if test="gameId != null "> and game_id = #{gameId}</if>
            <if test="svrIp != null  and svrIp != ''"> and svr_ip = #{svrIp}</if>
            <if test="svrPort != null "> and svr_port = #{svrPort}</if>
            <if test="svrPayCallback != null  and svrPayCallback != ''"> and svr_pay_callback = #{svrPayCallback}</if>
            <if test="svrExtconfig != null  and svrExtconfig != ''"> and svr_extconfig = #{svrExtconfig}</if>
            <if test="mapSvrId != null  and mapSvrId != ''"> and map_svr_id = #{mapSvrId}</if>
            <if test="groupType != null "> and group_type = #{groupType}</if>
            <if test="areaId != null "> and area_id = #{areaId}</if>
            <if test="mergeStatus != null "> and merge_status = #{mergeStatus}</if>
            <if test="createUser != null  and createUser != ''"> and create_user = #{createUser}</if>
            <if test="updateUser != null  and updateUser != ''"> and update_user = #{updateUser}</if>
            <if test="source != null "> and source = #{source}</if>
            <if test="mapAreaId != null  and mapAreaId != ''"> and map_area_id = #{mapAreaId}</if>
        </where>
    </select>
    
    <select id="selectTX8GameServerById" parameterType="Long" resultMap="TX8GameServerResult">
        <include refid="selectTX8GameServerVo"/>
        where svr_id = #{svrId}
    </select>
        
    <insert id="insertTX8GameServer" parameterType="TX8GameServer" useGeneratedKeys="true" keyProperty="svrId">
        insert into t_x8_game_server
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="svrName != null and svrName != ''">svr_name,</if>
            <if test="gameId != null">game_id,</if>
            <if test="svrIp != null and svrIp != ''">svr_ip,</if>
            <if test="svrPort != null">svr_port,</if>
            <if test="svrPayCallback != null and svrPayCallback != ''">svr_pay_callback,</if>
            <if test="svrExtconfig != null">svr_extconfig,</if>
            <if test="mapSvrId != null and mapSvrId != ''">map_svr_id,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="createTime != null">create_time,</if>
            <if test="groupType != null">group_type,</if>
            <if test="areaId != null">area_id,</if>
            <if test="mergeStatus != null">merge_status,</if>
            <if test="createUser != null">create_user,</if>
            <if test="updateUser != null">update_user,</if>
            <if test="source != null">source,</if>
            <if test="mapAreaId != null">map_area_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="svrName != null and svrName != ''">#{svrName},</if>
            <if test="gameId != null">#{gameId},</if>
            <if test="svrIp != null and svrIp != ''">#{svrIp},</if>
            <if test="svrPort != null">#{svrPort},</if>
            <if test="svrPayCallback != null and svrPayCallback != ''">#{svrPayCallback},</if>
            <if test="svrExtconfig != null">#{svrExtconfig},</if>
            <if test="mapSvrId != null and mapSvrId != ''">#{mapSvrId},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="groupType != null">#{groupType},</if>
            <if test="areaId != null">#{areaId},</if>
            <if test="mergeStatus != null">#{mergeStatus},</if>
            <if test="createUser != null">#{createUser},</if>
            <if test="updateUser != null">#{updateUser},</if>
            <if test="source != null">#{source},</if>
            <if test="mapAreaId != null">#{mapAreaId},</if>
         </trim>
    </insert>

    <update id="updateTX8GameServer" parameterType="TX8GameServer">
        update t_x8_game_server
        <trim prefix="SET" suffixOverrides=",">
            <if test="svrName != null and svrName != ''">svr_name = #{svrName},</if>
            <if test="gameId != null">game_id = #{gameId},</if>
            <if test="svrIp != null and svrIp != ''">svr_ip = #{svrIp},</if>
            <if test="svrPort != null">svr_port = #{svrPort},</if>
            <if test="svrPayCallback != null and svrPayCallback != ''">svr_pay_callback = #{svrPayCallback},</if>
            <if test="svrExtconfig != null">svr_extconfig = #{svrExtconfig},</if>
            <if test="mapSvrId != null and mapSvrId != ''">map_svr_id = #{mapSvrId},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="groupType != null">group_type = #{groupType},</if>
            <if test="areaId != null">area_id = #{areaId},</if>
            <if test="mergeStatus != null">merge_status = #{mergeStatus},</if>
            <if test="createUser != null">create_user = #{createUser},</if>
            <if test="updateUser != null">update_user = #{updateUser},</if>
            <if test="source != null">source = #{source},</if>
            <if test="mapAreaId != null">map_area_id = #{mapAreaId},</if>
        </trim>
        where svr_id = #{svrId}
    </update>

    <delete id="deleteTX8GameServerById" parameterType="Long">
        delete from t_x8_game_server where svr_id = #{svrId}
    </delete>

    <delete id="deleteTX8GameServerByIds" parameterType="String">
        delete from t_x8_game_server where svr_id in 
        <foreach item="svrId" collection="array" open="(" separator="," close=")">
            #{svrId}
        </foreach>
    </delete>

    <select id="selectServerInfo" resultMap="TX8GameServerResult">
        SELECT * FROM t_x8_game_server txgs WHERE txgs.group_type &gt;= 0 AND txgs.group_type &lt; 100;
    </select>
</mapper>