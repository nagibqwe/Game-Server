            <if test="svrTag != null  and svrTag != ''"> and svr_tag = #{svrTag}</if>
            <if test="sceId != null  and sceId != ''"> and sce_id = #{sceId}</if>
            <if test="svrPreStatus != null "> and svr_pre_status = #{svrPreStatus}</if>
            <if test="svrPreTag != null  and svrPreTag != ''"> and svr_pre_tag = #{svrPreTag}</if>
            <if test="svrPreStatusDate != null  and svrPreStatusDate != ''"> and svr_pre_status_date = #{svrPreStatusDate}</if>
