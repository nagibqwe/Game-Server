            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="sceId != null">sce_id = #{sceId},</if>
            <if test="svrPreStatus != null">svr_pre_status = #{svrPreStatus},</if>
            <if test="svrPreTag != null">svr_pre_tag = #{svrPreTag},</if>
