    <select id="selectTX8ServerPolicyList" parameterType="TX8ServerPolicy" resultMap="TX8ServerPolicyResult">
        <include refid="selectTX8ServerPolicyVo"/>
        <where>  
            <if test="gameId != null "> and game_id = #{gameId}</if>
            <if test="chnId != null "> and chn_id = #{chnId}</if>
            <if test="svrId != null "> and svr_id = #{svrId}</if>
            <if test="sortId != null "> and sort_id = #{sortId}</if>
