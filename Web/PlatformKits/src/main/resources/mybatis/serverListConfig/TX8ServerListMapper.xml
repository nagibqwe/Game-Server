<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kits.project.serverListConfig.x8serverList.mapper.TX8ServerListMapper">
    
    <resultMap type="TX8ServerList" id="TX8ServerListResult">
        <result property="policyId"    column="policy_id"    />
        <result property="policyName"    column="policy_name"    />
        <result property="gameId"    column="game_id"    />
        <result property="chnIds"    column="chn_ids"    />
        <result property="svrPolicyIds"    column="svr_policy_ids"    />
        <result property="updateUser"    column="update_user"    />
        <result property="status"    column="status"    />
        <result property="startIdx"    column="start_idx"    />
        <result property="updateTime"    column="update_time"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectTX8ServerListVo">
        select policy_id, policy_name, game_id, chn_ids, svr_policy_ids, update_user, status, start_idx, update_time, create_time from t_x8_server_list
    </sql>

    <select id="selectTX8ServerListList" parameterType="TX8ServerList" resultMap="TX8ServerListResult">
        <include refid="selectTX8ServerListVo"/>
        <where>  
            <if test="policyName != null  and policyName != ''"> and policy_name like concat('%', #{policyName}, '%')</if>
            <if test="gameId != null "> and game_id = #{gameId}</if>
            <if test="chnIds != null  and chnIds != ''"> and chn_ids = #{chnIds}</if>
            <if test="svrPolicyIds != null  and svrPolicyIds != ''"> and svr_policy_ids = #{svrPolicyIds}</if>
            <if test="updateUser != null  and updateUser != ''"> and update_user = #{updateUser}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="startIdx != null "> and start_idx = #{startIdx}</if>
        </where>
    </select>
    
    <select id="selectTX8ServerListById" parameterType="Long" resultMap="TX8ServerListResult">
        <include refid="selectTX8ServerListVo"/>
        where policy_id = #{policyId}
    </select>
        
    <insert id="insertTX8ServerList" parameterType="TX8ServerList" useGeneratedKeys="true" keyProperty="policyId">
        insert into t_x8_server_list
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="policyName != null and policyName != ''">policy_name,</if>
            <if test="gameId != null">game_id,</if>
            <if test="chnIds != null and chnIds != ''">chn_ids,</if>
            <if test="svrPolicyIds != null and svrPolicyIds != ''">svr_policy_ids,</if>
            <if test="updateUser != null">update_user,</if>
            <if test="status != null">status,</if>
            <if test="startIdx != null">start_idx,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="policyName != null and policyName != ''">#{policyName},</if>
            <if test="gameId != null">#{gameId},</if>
            <if test="chnIds != null and chnIds != ''">#{chnIds},</if>
            <if test="svrPolicyIds != null and svrPolicyIds != ''">#{svrPolicyIds},</if>
            <if test="updateUser != null">#{updateUser},</if>
            <if test="status != null">#{status},</if>
            <if test="startIdx != null">#{startIdx},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateTX8ServerList" parameterType="TX8ServerList">
        update t_x8_server_list
        <trim prefix="SET" suffixOverrides=",">
            <if test="policyName != null and policyName != ''">policy_name = #{policyName},</if>
            <if test="gameId != null">game_id = #{gameId},</if>
            <if test="chnIds != null and chnIds != ''">chn_ids = #{chnIds},</if>
            <if test="svrPolicyIds != null and svrPolicyIds != ''">svr_policy_ids = #{svrPolicyIds},</if>
            <if test="updateUser != null">update_user = #{updateUser},</if>
            <if test="status != null">status = #{status},</if>
            <if test="startIdx != null">start_idx = #{startIdx},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where policy_id = #{policyId}
    </update>

    <delete id="deleteTX8ServerListById" parameterType="Long">
        delete from t_x8_server_list where policy_id = #{policyId}
    </delete>

    <delete id="deleteTX8ServerListByIds" parameterType="String">
        delete from t_x8_server_list where policy_id in 
        <foreach item="policyId" collection="array" open="(" separator="," close=")">
            #{policyId}
        </foreach>
    </delete>
</mapper>