<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gm.project.gmtool.activeCodebatch.mapper.CodeBatchMapper">
    
    <resultMap type="CodeBatch" id="CodeBatchResult">
        <result property="id"    column="id"    />
        <result property="batchId"    column="batchId"    />
        <result property="userId"    column="userId"    />
        <result property="time"    column="time"    />
        <result property="platform"    column="platform"    />
        <result property="isUniversal"    column="isUniversal"    />
    </resultMap>

    <sql id="selectCodeBatchVo">
        select id, batchId, userId, time, platform, isUniversal from t_code_batch
    </sql>

    <select id="selectCodeBatchList" parameterType="CodeBatch" resultMap="CodeBatchResult">
        <include refid="selectCodeBatchVo"/>
        <where>  
            <if test="batchId != null "> and batchId = #{batchId}</if>
            <if test="userId != null "> and userId = #{userId}</if>
            <if test="time != null "> and time = #{time}</if>
            <if test="platform != null  and platform != ''"> and platform = #{platform}</if>
            <if test="isUniversal != null "> and isUniversal = #{isUniversal}</if>
        </where>
    </select>
    
    <select id="selectCodeBatchById" parameterType="Long" resultMap="CodeBatchResult">
        <include refid="selectCodeBatchVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertCodeBatch" parameterType="CodeBatch" useGeneratedKeys="true" keyProperty="id">
        insert into t_code_batch
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="batchId != null">batchId,</if>
            <if test="userId != null">userId,</if>
            <if test="time != null">time,</if>
            <if test="platform != null">platform,</if>
            <if test="isUniversal != null">isUniversal,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="batchId != null">#{batchId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="time != null">#{time},</if>
            <if test="platform != null">#{platform},</if>
            <if test="isUniversal != null">#{isUniversal},</if>
         </trim>
    </insert>

    <update id="updateCodeBatch" parameterType="CodeBatch">
        update t_code_batch
        <trim prefix="SET" suffixOverrides=",">
            <if test="batchId != null">batchId = #{batchId},</if>
            <if test="userId != null">userId = #{userId},</if>
            <if test="time != null">time = #{time},</if>
            <if test="platform != null">platform = #{platform},</if>
            <if test="isUniversal != null">isUniversal = #{isUniversal},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCodeBatchById" parameterType="Long">
        delete from t_code_batch where id = #{id}
    </delete>

    <delete id="deleteCodeBatchByIds" parameterType="String">
        delete from t_code_batch where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectMaxId" resultType="int">
        select MAX(id) FROM t_code_batch;
    </select>
    <select id="selectBatchId" parameterType="Integer" resultType="int">
        select COUNT(*) FROM t_code_batch WHERE batchId = #{batchId};
    </select>
</mapper>