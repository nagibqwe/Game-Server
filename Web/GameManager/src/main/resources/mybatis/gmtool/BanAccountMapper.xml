<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gm.project.gmtool.banAccount.mapper.BanAccountMapper">
    
    <resultMap type="BanAccount" id="BanAccountResult">
        <result property="id"    column="id"    />
        <result property="con"    column="con"    />
        <result property="endTime"    column="endTime"    />
        <result property="state"    column="state"    />
        <result property="reason"    column="reason"    />
    </resultMap>

    <sql id="selectBanAccountVo">
        select id, con, endTime, state, reason from t_ban_account
    </sql>

    <select id="selectBanAccountList" parameterType="BanAccount" resultMap="BanAccountResult">
        <include refid="selectBanAccountVo"/>
        <where>  
            <if test="con != null  and con != ''"> and con = #{con}</if>
            <if test="endTime != null  and endTime != ''"> and endTime = #{endTime}</if>
            <if test="state != null "> and state = #{state}</if>
            <if test="reason != null  and reason != ''"> and reason = #{reason}</if>
        </where>
        order by id desc
    </select>
    
    <select id="selectBanAccountById" parameterType="Long" resultMap="BanAccountResult">
        <include refid="selectBanAccountVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertBanAccount" parameterType="BanAccount" useGeneratedKeys="true" keyProperty="id">
        insert into t_ban_account
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="con != null">con,</if>
            <if test="endTime != null">endTime,</if>
            <if test="state != null">state,</if>
            <if test="reason != null">reason,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="con != null">#{con},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="state != null">#{state},</if>
            <if test="reason != null">#{reason},</if>
         </trim>
    </insert>

    <update id="updateBanAccount" parameterType="BanAccount">
        update t_ban_account
        <trim prefix="SET" suffixOverrides=",">
            <if test="con != null">con = #{con},</if>
            <if test="endTime != null">endTime = #{endTime},</if>
            <if test="state != null">state = #{state},</if>
            <if test="reason != null">reason = #{reason},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteBanAccountById" parameterType="Long">
        delete from t_ban_account where id = #{id}
    </delete>

    <delete id="deleteBanAccountByIds" parameterType="String">
        delete from t_ban_account where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>