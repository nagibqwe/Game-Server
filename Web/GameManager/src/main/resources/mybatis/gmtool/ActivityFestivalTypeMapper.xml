<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gm.project.gmtool.activityFestivalType.mapper.ActivityFestivalTypeMapper">
    
    <resultMap type="ActivityFestivalType" id="ActivityFestivalTypeResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
    </resultMap>

    <sql id="selectActivityFestivalTypeVo">
        select id, name from t_activity_festival_type
    </sql>

    <select id="selectActivityFestivalTypeList" parameterType="ActivityFestivalType" resultMap="ActivityFestivalTypeResult">
        <include refid="selectActivityFestivalTypeVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
        </where>
    </select>
    
    <select id="selectActivityFestivalTypeById" parameterType="Integer" resultMap="ActivityFestivalTypeResult">
        <include refid="selectActivityFestivalTypeVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertActivityFestivalType" parameterType="ActivityFestivalType">
        insert into t_activity_festival_type
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="name != null">name,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="name != null">#{name},</if>
         </trim>
    </insert>

    <update id="updateActivityFestivalType" parameterType="ActivityFestivalType">
        update t_activity_festival_type
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteActivityFestivalTypeById" parameterType="Integer">
        delete from t_activity_festival_type where id = #{id}
    </delete>

    <delete id="deleteActivityFestivalTypeByIds" parameterType="String">
        delete from t_activity_festival_type where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <delete id="deleteAllActFestivalType">
        delete from t_activity_festival_type
    </delete>
    <select id="selectActivityFestivalTypeByIds" parameterType="Integer" resultMap="ActivityFestivalTypeResult">
        select * from t_activity_festival_type where id in
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>