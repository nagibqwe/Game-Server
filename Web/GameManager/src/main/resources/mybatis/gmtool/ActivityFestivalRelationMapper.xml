<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gm.project.gmtool.activityFestivalRelation.mapper.ActivityFestivalRelationMapper">
    
    <resultMap type="ActivityFestivalRelation" id="ActivityFestivalRelationResult">
        <result property="logicId"    column="logic_id"    />
        <result property="festivalId"    column="festival_id"    />
    </resultMap>

    <sql id="selectActivityFestivalRelationVo">
        select logic_id, festival_id from t_activity_festival_relation
    </sql>

    <select id="selectActivityFestivalRelationList" parameterType="ActivityFestivalRelation" resultMap="ActivityFestivalRelationResult">
        <include refid="selectActivityFestivalRelationVo"/>
        <where>  
            <if test="logicId != null "> and logic_id = #{logicId}</if>
            <if test="festivalId != null "> and festival_id = #{festivalId}</if>
        </where>
    </select>
    
    <select id="selectActivityFestivalRelationById" parameterType="Integer" resultMap="ActivityFestivalRelationResult">
        <include refid="selectActivityFestivalRelationVo"/>
        where logic_id = #{logicId}
    </select>
        
    <insert id="insertActivityFestivalRelation" parameterType="ActivityFestivalRelation">
        insert into t_activity_festival_relation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="logicId != null">logic_id,</if>
            <if test="festivalId != null">festival_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="logicId != null">#{logicId},</if>
            <if test="festivalId != null">#{festivalId},</if>
         </trim>
    </insert>

    <update id="updateActivityFestivalRelation" parameterType="ActivityFestivalRelation">
        update t_activity_festival_relation
        <trim prefix="SET" suffixOverrides=",">
            <if test="festivalId != null">festival_id = #{festivalId},</if>
        </trim>
        where logic_id = #{logicId}
    </update>

    <delete id="deleteActivityFestivalRelationById" parameterType="Integer">
        delete from t_activity_festival_relation where logic_id = #{logicId}
    </delete>

    <delete id="deleteActivityFestivalRelationByIds" parameterType="String">
        delete from t_activity_festival_relation where logic_id in 
        <foreach item="logicId" collection="array" open="(" separator="," close=")">
            #{logicId}
        </foreach>
    </delete>

    <delete id="deleteAllActFestivalRelation">
        delete from t_activity_festival_relation
    </delete>

    <select id="selectActFestivalRelationByLogicId" parameterType="Integer" resultType="Integer">
        select festival_id from t_activity_festival_relation where logic_id = #{logicId}
    </select>

</mapper>