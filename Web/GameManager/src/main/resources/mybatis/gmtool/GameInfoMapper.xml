<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gm.project.gmtool.gameInfo.mapper.GameInfoMapper">
    
    <resultMap type="GameInfo" id="GameInfoResult">
        <result property="gameId"    column="gameId"    />
        <result property="rechargeSecretkey"    column="rechargeSecretkey"    />
        <result property="autoFirstServerId"    column="autoFirstServerId"    />
        <result property="autoUserCount"    column="autoUserCount"    />
        <result property="autoServerId"    column="autoServerId"    />
        <result property="time"    column="time"    />
    </resultMap>

    <sql id="selectGameInfoVo">
        select gameId, rechargeSecretkey, autoFirstServerId, autoUserCount, autoServerId, time from game_info
    </sql>

    <select id="selectGameInfoList" parameterType="GameInfo" resultMap="GameInfoResult">
        <include refid="selectGameInfoVo"/>
        <where>  
            <if test="rechargeSecretkey != null  and rechargeSecretkey != ''"> and rechargeSecretkey = #{rechargeSecretkey}</if>
            <if test="autoFirstServerId != null "> and autoFirstServerId = #{autoFirstServerId}</if>
            <if test="autoUserCount != null "> and autoUserCount = #{autoUserCount}</if>
            <if test="autoServerId != null "> and autoServerId = #{autoServerId}</if>
            <if test="time != null "> and time = #{time}</if>
        </where>
    </select>
    
    <select id="selectGameInfoById" parameterType="Integer" resultMap="GameInfoResult">
        <include refid="selectGameInfoVo"/>
        where gameId = #{gameId}
    </select>
        
    <insert id="insertGameInfo" parameterType="GameInfo">
        insert into game_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="gameId != null">gameId,</if>
            <if test="rechargeSecretkey != null">rechargeSecretkey,</if>
            <if test="autoFirstServerId != null">autoFirstServerId,</if>
            <if test="autoUserCount != null">autoUserCount,</if>
            <if test="autoServerId != null">autoServerId,</if>
            <if test="time != null">time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="gameId != null">#{gameId},</if>
            <if test="rechargeSecretkey != null">#{rechargeSecretkey},</if>
            <if test="autoFirstServerId != null">#{autoFirstServerId},</if>
            <if test="autoUserCount != null">#{autoUserCount},</if>
            <if test="autoServerId != null">#{autoServerId},</if>
            <if test="time != null">#{time},</if>
         </trim>
    </insert>

    <update id="updateGameInfo" parameterType="GameInfo">
        update game_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="rechargeSecretkey != null">rechargeSecretkey = #{rechargeSecretkey},</if>
            <if test="autoFirstServerId != null">autoFirstServerId = #{autoFirstServerId},</if>
            <if test="autoUserCount != null">autoUserCount = #{autoUserCount},</if>
            <if test="autoServerId != null">autoServerId = #{autoServerId},</if>
            <if test="time != null">time = #{time},</if>
        </trim>
        where gameId = #{gameId}
    </update>

    <delete id="deleteGameInfoById" parameterType="Integer">
        delete from game_info where gameId = #{gameId}
    </delete>

    <delete id="deleteGameInfoByIds" parameterType="String">
        delete from game_info where gameId in 
        <foreach item="gameId" collection="array" open="(" separator="," close=")">
            #{gameId}
        </foreach>
    </delete>

</mapper>