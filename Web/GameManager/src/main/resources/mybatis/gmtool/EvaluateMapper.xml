<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gm.project.gmtool.evaluate.mapper.EvaluateMapper">
    
    <resultMap type="Evaluate" id="EvaluateResult">
        <result property="id"    column="id"    />
        <result property="serverId"    column="serverId"    />
        <result property="eType"    column="eType"    />
        <result property="state"    column="state"    />
        <result property="actionTime"    column="actionTime"    />
        <result property="reason"    column="reason"    />
        <result property="isDelete"    column="isDelete"    />
        <result property="actionUser"    column="actionUser"    />
    </resultMap>

    <sql id="selectEvaluateVo">
        select id, serverId, eType, state, actionTime, reason, isDelete, actionUser from t_evaluate
    </sql>

    <select id="selectEvaluateList" parameterType="Evaluate" resultMap="EvaluateResult">
        <include refid="selectEvaluateVo"/>
        <where>
            isDelete = 0
            <if test="serverId != null "> and serverId = #{serverId}</if>
            <if test="eType != null "> and eType = #{eType}</if>
            <if test="state != null "> and state = #{state}</if>
            <if test="actionTime != null "> and actionTime = #{actionTime}</if>
            <if test="reason != null  and reason != ''"> and reason = #{reason}</if>
            <if test="actionUser != null  and actionUser != ''"> and actionUser = #{actionUser}</if>
        </where>
        order by id desc
    </select>
    
    <select id="selectEvaluateById" parameterType="Integer" resultMap="EvaluateResult">
        <include refid="selectEvaluateVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertEvaluate" parameterType="Evaluate" useGeneratedKeys="true" keyProperty="id">
        insert into t_evaluate
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="serverId != null">serverId,</if>
            <if test="eType != null">eType,</if>
            <if test="state != null">state,</if>
            <if test="actionTime != null">actionTime,</if>
            <if test="reason != null">reason,</if>
            <if test="isDelete != null">isDelete,</if>
            <if test="actionUser != null">actionUser,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="serverId != null">#{serverId},</if>
            <if test="eType != null">#{eType},</if>
            <if test="state != null">#{state},</if>
            <if test="actionTime != null">#{actionTime},</if>
            <if test="reason != null">#{reason},</if>
            <if test="isDelete != null">#{isDelete},</if>
            <if test="actionUser != null">#{actionUser},</if>
         </trim>
    </insert>

    <update id="updateEvaluate" parameterType="Evaluate">
        update t_evaluate
        <trim prefix="SET" suffixOverrides=",">
            <if test="serverId != null">serverId = #{serverId},</if>
            <if test="eType != null">eType = #{eType},</if>
            <if test="state != null">state = #{state},</if>
            <if test="actionTime != null">actionTime = #{actionTime},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="isDelete != null">isDelete = #{isDelete},</if>
            <if test="actionUser != null">actionUser = #{actionUser},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteEvaluateById" parameterType="Integer">
        delete from t_evaluate where id = #{id}
    </delete>

    <delete id="deleteEvaluateByIds" parameterType="String">
        delete from t_evaluate where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>