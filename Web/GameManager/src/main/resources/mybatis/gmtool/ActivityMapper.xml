<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gm.project.gmtool.activity.mapper.ActivityMapper">
    
    <resultMap type="Activity" id="ActivityResult">
        <result property="id"    column="id"    />
        <result property="type"    column="type"    />
        <result property="subType"    column="subType"    />
        <result property="minLv"    column="minLv"    />
        <result property="maxLv"    column="maxLv"    />
        <result property="tag"    column="tag"    />
        <result property="sort"    column="sort"    />
        <result property="name"    column="name"    />
        <result property="description"    column="description"    />
        <result property="timeType"    column="timeType"    />
        <result property="openServerOffsetBegin"    column="openServerOffsetBegin"    />
        <result property="openServerOffset"    column="openServerOffset"    />
        <result property="beginTime"    column="beginTime"    />
        <result property="endTime"    column="endTime"    />
        <result property="openServerRecordOffsetBegin"    column="openServerRecordOffsetBegin"    />
        <result property="openServerRecordOffset"    column="openServerRecordOffset"    />
        <result property="startRecordTime"    column="startRecordTime"    />
        <result property="endRecordTime"    column="endRecordTime"    />
        <result property="state"    column="state"    />
        <result property="toSidList"    column="toSidList"    />
        <result property="okSidList"    column="okSidList"    />
        <result property="isDeleted"    column="isDeleted"    />
        <result property="autoSend"    column="autoSend"    />
        <result property="isOpenServer"    column="isOpenServer"    />
        <result property="custom"    column="custom"    />
        <result property="cover"    column="cover"    />
        <result property="configData"    column="configData"    />
    </resultMap>

    <sql id="selectActivityVo">
        select id, type, subType, minLv, maxLv, tag, sort, name, description, timeType, openServerOffsetBegin, openServerOffset, beginTime, endTime, openServerRecordOffsetBegin, openServerRecordOffset, startRecordTime, endRecordTime, state, toSidList, okSidList, isDeleted, autoSend, isOpenServer, custom, cover, configData from t_activity
    </sql>

    <select id="selectActivityList" parameterType="Activity" resultMap="ActivityResult">
        <include refid="selectActivityVo"/>
        <where>
            isDeleted = 0
            <if test="type != null "> and type = #{type}</if>
            <if test="subType != null "> and subType = #{subType}</if>
            <if test="minLv != null "> and minLv = #{minLv}</if>
            <if test="maxLv != null "> and maxLv = #{maxLv}</if>
            <if test="tag != null "> and tag = #{tag}</if>
            <if test="sort != null "> and sort = #{sort}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="timeType != null "> and timeType = #{timeType}</if>
            <if test="openServerOffsetBegin != null "> and openServerOffsetBegin = #{openServerOffsetBegin}</if>
            <if test="openServerOffset != null "> and openServerOffset = #{openServerOffset}</if>
            <if test="beginTime != null  and beginTime != ''"> and beginTime = #{beginTime}</if>
            <if test="endTime != null  and endTime != ''"> and endTime = #{endTime}</if>
            <if test="openServerRecordOffsetBegin != null "> and openServerRecordOffsetBegin = #{openServerRecordOffsetBegin}</if>
            <if test="openServerRecordOffset != null "> and openServerRecordOffset = #{openServerRecordOffset}</if>
            <if test="startRecordTime != null  and startRecordTime != ''"> and startRecordTime = #{startRecordTime}</if>
            <if test="endRecordTime != null  and endRecordTime != ''"> and endRecordTime = #{endRecordTime}</if>
            <if test="state != null "> and state = #{state}</if>
            <if test="toSidList != null  and toSidList != ''"> and toSidList = #{toSidList}</if>
            <if test="okSidList != null  and okSidList != ''"> and okSidList = #{okSidList}</if>
            <if test="autoSend != null "> and autoSend = #{autoSend}</if>
            <if test="isOpenServer != null "> and isOpenServer = #{isOpenServer}</if>
            <if test="custom != null  and custom != ''"> and custom = #{custom}</if>
            <if test="cover != null "> and cover = #{cover}</if>
            <if test="configData != null  and configData != ''"> and configData = #{configData}</if>
        </where>
        order by id desc
    </select>

    <select id="selectActivityByActIds" parameterType="java.lang.String" resultMap="ActivityResult">
        <include refid="selectActivityVo"/>
        <where>
            isDeleted = 0
            and id in(${actIds})
        </where>
        order by id desc
    </select>
    
    <select id="selectActivityById" parameterType="Integer" resultMap="ActivityResult">
        <include refid="selectActivityVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertActivity" parameterType="Activity" useGeneratedKeys="true" keyProperty="id">
        insert into t_activity
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="type != null">type,</if>
            <if test="subType != null">subType,</if>
            <if test="minLv != null">minLv,</if>
            <if test="maxLv != null">maxLv,</if>
            <if test="tag != null">tag,</if>
            <if test="sort != null">sort,</if>
            <if test="name != null">name,</if>
            <if test="description != null">description,</if>
            <if test="timeType != null">timeType,</if>
            <if test="openServerOffsetBegin != null">openServerOffsetBegin,</if>
            <if test="openServerOffset != null">openServerOffset,</if>
            <if test="beginTime != null">beginTime,</if>
            <if test="endTime != null">endTime,</if>
            <if test="openServerRecordOffsetBegin != null">openServerRecordOffsetBegin,</if>
            <if test="openServerRecordOffset != null">openServerRecordOffset,</if>
            <if test="startRecordTime != null">startRecordTime,</if>
            <if test="endRecordTime != null">endRecordTime,</if>
            <if test="state != null">state,</if>
            <if test="toSidList != null">toSidList,</if>
            <if test="okSidList != null">okSidList,</if>
            <if test="isDeleted != null">isDeleted,</if>
            <if test="autoSend != null">autoSend,</if>
            <if test="isOpenServer != null">isOpenServer,</if>
            <if test="custom != null">custom,</if>
            <if test="cover != null">cover,</if>
            <if test="configData != null">configData,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="type != null">#{type},</if>
            <if test="subType != null">#{subType},</if>
            <if test="minLv != null">#{minLv},</if>
            <if test="maxLv != null">#{maxLv},</if>
            <if test="tag != null">#{tag},</if>
            <if test="sort != null">#{sort},</if>
            <if test="name != null">#{name},</if>
            <if test="description != null">#{description},</if>
            <if test="timeType != null">#{timeType},</if>
            <if test="openServerOffsetBegin != null">#{openServerOffsetBegin},</if>
            <if test="openServerOffset != null">#{openServerOffset},</if>
            <if test="beginTime != null">#{beginTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="openServerRecordOffsetBegin != null">#{openServerRecordOffsetBegin},</if>
            <if test="openServerRecordOffset != null">#{openServerRecordOffset},</if>
            <if test="startRecordTime != null">#{startRecordTime},</if>
            <if test="endRecordTime != null">#{endRecordTime},</if>
            <if test="state != null">#{state},</if>
            <if test="toSidList != null">#{toSidList},</if>
            <if test="okSidList != null">#{okSidList},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
            <if test="autoSend != null">#{autoSend},</if>
            <if test="isOpenServer != null">#{isOpenServer},</if>
            <if test="custom != null">#{custom},</if>
            <if test="cover != null">#{cover},</if>
            <if test="configData != null">#{configData},</if>
         </trim>
    </insert>

    <update id="updateActivity" parameterType="Activity">
        update t_activity
        <trim prefix="SET" suffixOverrides=",">
            <if test="type != null">type = #{type},</if>
            <if test="subType != null">subType = #{subType},</if>
            <if test="minLv != null">minLv = #{minLv},</if>
            <if test="maxLv != null">maxLv = #{maxLv},</if>
            <if test="tag != null">tag = #{tag},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="timeType != null">timeType = #{timeType},</if>
            <if test="openServerOffsetBegin != null">openServerOffsetBegin = #{openServerOffsetBegin},</if>
            <if test="openServerOffset != null">openServerOffset = #{openServerOffset},</if>
            <if test="beginTime != null">beginTime = #{beginTime},</if>
            <if test="endTime != null">endTime = #{endTime},</if>
            <if test="openServerRecordOffsetBegin != null">openServerRecordOffsetBegin = #{openServerRecordOffsetBegin},</if>
            <if test="openServerRecordOffset != null">openServerRecordOffset = #{openServerRecordOffset},</if>
            <if test="startRecordTime != null">startRecordTime = #{startRecordTime},</if>
            <if test="endRecordTime != null">endRecordTime = #{endRecordTime},</if>
            <if test="state != null">state = #{state},</if>
            <if test="toSidList != null">toSidList = #{toSidList},</if>
            <if test="okSidList != null">okSidList = #{okSidList},</if>
            <if test="isDeleted != null">isDeleted = #{isDeleted},</if>
            <if test="autoSend != null">autoSend = #{autoSend},</if>
            <if test="isOpenServer != null">isOpenServer = #{isOpenServer},</if>
            <if test="custom != null">custom = #{custom},</if>
            <if test="cover != null">cover = #{cover},</if>
            <if test="configData != null">configData = #{configData},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteActivityById" parameterType="Integer">
        delete from t_activity where id = #{id}
    </delete>

    <delete id="deleteActivityByIds" parameterType="String">
        delete from t_activity where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>