<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gm.project.gmtool.activityLuckyValue.mapper.ActivityLuckyValueMapper">
    
    <resultMap type="ActivityLuckyValue" id="ActivityLuckyValueResult">
        <result property="id"    column="id"    />
        <result property="totalLuckyValue"    column="totalLuckyValue"    />
        <result property="tips"    column="tips"    />
        <result property="state"    column="state"    />
        <result property="platform"    column="platform"    />
        <result property="toSidList"    column="toSidList"    />
        <result property="okSidList"    column="okSidList"    />
        <result property="isDeleted"    column="isDeleted"    />
        <result property="cover"    column="cover"    />
    </resultMap>

    <sql id="selectActivityLuckyValueVo">
        select id, totalLuckyValue, tips, state, platform, toSidList, okSidList, isDeleted, cover from t_activity_lucky_value
    </sql>

    <select id="selectActivityLuckyValueList" parameterType="ActivityLuckyValue" resultMap="ActivityLuckyValueResult">
        <include refid="selectActivityLuckyValueVo"/>
        <where>
            isDeleted = 0
            <if test="totalLuckyValue != null "> and totalLuckyValue = #{totalLuckyValue}</if>
            <if test="tips != null  and tips != ''"> and tips = #{tips}</if>
            <if test="state != null "> and state = #{state}</if>
            <if test="platform != null  and platform != ''"> and platform = #{platform}</if>
            <if test="toSidList != null  and toSidList != ''"> and toSidList = #{toSidList}</if>
            <if test="okSidList != null  and okSidList != ''"> and okSidList = #{okSidList}</if>
            <if test="cover != null "> and cover = #{cover}</if>
        </where>
    </select>
    
    <select id="selectActivityLuckyValueById" parameterType="Integer" resultMap="ActivityLuckyValueResult">
        <include refid="selectActivityLuckyValueVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertActivityLuckyValue" parameterType="ActivityLuckyValue" useGeneratedKeys="true" keyProperty="id">
        insert into t_activity_lucky_value
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="totalLuckyValue != null">totalLuckyValue,</if>
            <if test="tips != null">tips,</if>
            <if test="state != null">state,</if>
            <if test="platform != null">platform,</if>
            <if test="toSidList != null">toSidList,</if>
            <if test="okSidList != null">okSidList,</if>
            <if test="isDeleted != null">isDeleted,</if>
            <if test="cover != null">cover,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="totalLuckyValue != null">#{totalLuckyValue},</if>
            <if test="tips != null">#{tips},</if>
            <if test="state != null">#{state},</if>
            <if test="platform != null">#{platform},</if>
            <if test="toSidList != null">#{toSidList},</if>
            <if test="okSidList != null">#{okSidList},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
            <if test="cover != null">#{cover},</if>
         </trim>
    </insert>

    <update id="updateActivityLuckyValue" parameterType="ActivityLuckyValue">
        update t_activity_lucky_value
        <trim prefix="SET" suffixOverrides=",">
            <if test="totalLuckyValue != null">totalLuckyValue = #{totalLuckyValue},</if>
            <if test="tips != null">tips = #{tips},</if>
            <if test="state != null">state = #{state},</if>
            <if test="platform != null">platform = #{platform},</if>
            <if test="toSidList != null">toSidList = #{toSidList},</if>
            <if test="okSidList != null">okSidList = #{okSidList},</if>
            <if test="isDeleted != null">isDeleted = #{isDeleted},</if>
            <if test="cover != null">cover = #{cover},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteActivityLuckyValueById" parameterType="Integer">
        delete from t_activity_lucky_value where id = #{id}
    </delete>

    <delete id="deleteActivityLuckyValueByIds" parameterType="String">
        delete from t_activity_lucky_value where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>