<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper  PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN"  "http://ibatis.apache.org/dtd/ibatis-3-mapper.dtd">
<mapper namespace="activityData">
    <resultMap id="bean" type="com.game.db.bean.ActivityDataBean">
        <result column="type" property="type" jdbcType="INTEGER" />
        <result column="actData" property="actData" jdbcType="LONGVARCHAR" />
    </resultMap>

    <select id="selectAll" resultMap="bean">
        select * from activityData
    </select>

    <select id="select" parameterType="Integer" resultMap="bean">
        select * from activityData where `type` = #{type, jdbcType = INTEGER}
    </select>

    <insert id="insert" parameterType="com.game.db.bean.ActivityDataBean">
        insert into activityData (`type`,actData)
        values
        (
        #{type, jdbcType=INTEGER}, #{actData, jdbcType=LONGVARCHAR}
        )
    </insert>

    <update id="update" parameterType="com.game.db.bean.ActivityDataBean">
        update activityData set
        `type` = #{type,jdbcType=INTEGER},
        actData = #{actData,jdbcType=LONGVARCHAR}
        where
        `type` = #{type,jdbcType=INTEGER}
    </update>

    <delete id="delete" parameterType="Integer">
        delete from activityData where `type` = #{type, jdbcType=INTEGER};
    </delete>
</mapper>

