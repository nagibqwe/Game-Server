<?xml version="1.0" encoding="UTF-8" ?>  
<!DOCTYPE mapper  PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN"  "http://ibatis.apache.org/dtd/ibatis-3-mapper.dtd">
<mapper namespace = "marry">
    
    <resultMap id = "bean" type = "com.game.db.bean.MarryBean" >
        <result column = "marriageId" property = "marriageId" jdbcType = "BIGINT" />
        <result column = "aId" property = "aId" jdbcType = "BIGINT" />
        <result column = "bId" property = "bId" jdbcType = "BIGINT" />
        <result column = "time" property="time" jdbcType = "BIGINT" />
        <result column = "data" property="data" jdbcType = "LONGVARCHAR" />
    </resultMap>

    <resultMap id = "DeclarationBean" type = "com.game.marriage.struct.MarryDeclaration" >
        <result column = "roleId" property = "roleId" jdbcType = "BIGINT" />
        <result column = "declarationId" property = "declarationId" jdbcType = "INTEGER" />
        <result column = "timeout" property="timeout" jdbcType = "BIGINT" />
    </resultMap>

    <select id="selectAll" resultMap="bean">
        select * from marray;
    </select>

    <update id="update" parameterType="com.game.db.bean.MarryBean" >
        update marray set data = #{data,jdbcType=LONGVARCHAR},time = #{time,jdbcType=BIGINT},bId = #{bId,jdbcType=BIGINT},aId=#{aId,jdbcType=BIGINT}
        where marriageId = #{marriageId,jdbcType=BIGINT}
    </update>
    
    <insert id = "insert" parameterType = "com.game.db.bean.MarryBean">
        insert into marray (marriageId, aId, bId, time, data)
        values (
        #{marriageId, jdbcType = BIGINT},
        #{aId, jdbcType = BIGINT},
        #{bId, jdbcType = BIGINT},
        #{time, jdbcType = BIGINT},
        #{data, jdbcType = LONGVARCHAR}
        )
    </insert>

    <delete id = "delete" parameterType = "long">
        delete from marray where marriageId = #{marriageId, jdbcType = BIGINT}
    </delete>

    <select id="selectAllDeclaration" resultMap="DeclarationBean">
        select * from marry_declaration;
    </select>

    <delete id="deleteDeclaration" parameterType = "com.game.marriage.struct.MarryDeclaration">
        delete  from marry_declaration where roleId = #{roleId}
    </delete>
    <insert id="insertOrUpdateDeclaration" parameterType="com.game.marriage.struct.MarryDeclaration">
        insert into marry_declaration (roleId, declarationId, timeout)
        value ( #{roleId}, #{declarationId}, #{timeout})
        on duplicate key update declarationId = #{declarationId}, timeout = #{timeout}
    </insert>


</mapper>