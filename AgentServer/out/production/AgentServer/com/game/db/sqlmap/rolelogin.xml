<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper  PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN"  "http://ibatis.apache.org/dtd/ibatis-3-mapper.dtd">
<mapper namespace="rolelogin">
    <resultMap id="bean" type="com.game.db.bean.RoleLoginBean">
        <id column="roleId" property="roleId" jdbcType="BIGINT"/>
        <result column="userId" property="userId" jdbcType="BIGINT"/>
        <result column="serverId" property="serverId" jdbcType="INTEGER"/>
        <result column="roleName" property="roleName" jdbcType="VARCHAR"/>
        <result column="lv" property="lv" jdbcType="INTEGER"/>
        <result column="career" property="career" jdbcType="INTEGER"/>
        <result column="deleteTime" property="deleteTime" jdbcType="INTEGER" />
        <result column="fight" property="fight" jdbcType="BIGINT"/>
    </resultMap>

    <select id="selectAll" resultMap="bean">
        select * from rolelogin
    </select>

    <select id="selectByUserId" parameterType="long" resultMap="bean">
            select * from rolelogin where userId = #{userId,jdbcType=BIGINT}
    </select>

    <insert id="insert" parameterType="com.game.db.bean.RoleLoginBean">
            insert into rolelogin (roleId, userId, serverId, roleName, lv, career, deleteTime, fight)
            values (#{roleId,jdbcType=BIGINT}, #{userId,jdbcType=BIGINT}, #{serverId,jdbcType=INTEGER}, #{roleName,jdbcType=VARCHAR},
                    #{lv,jdbcType=INTEGER}, #{career,jdbcType=INTEGER}, #{deleteTime,jdbcType=INTEGER}, #{fight,jdbcType=BIGINT})
    </insert>

    <update id="update" parameterType="com.game.db.bean.RoleLoginBean">
            update rolelogin set roleName = #{roleName,jdbcType=VARCHAR},lv = #{lv,jdbcType=INTEGER},career = #{career,jdbcType=INTEGER}
            where roleId = #{roleId,jdbcType=BIGINT}
    </update>
</mapper>
