<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper  PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN"  "http://ibatis.apache.org/dtd/ibatis-3-mapper.dtd">
<mapper namespace="rechargetotalmoney">
    <resultMap id="bean" type="com.game.db.bean.RechargeTotalMoneyBean" >
            <id column="userId" property="userId" jdbcType="BIGINT" />
            <result column="rechargeTotalMoney" property="rechargeTotalMoney" jdbcType="INTEGER" />
        <result column="returnGold" property="returnGold" jdbcType="INTEGER" />
        <result column="userName" property="userName" jdbcType="VARCHAR" />
        <result column="platformAccount" property="platformAccount" jdbcType="VARCHAR" />

    </resultMap>

    <select id="selectAll" resultMap="bean">
        select * from rechargetotalmoney
    </select>

    <select id="selectByUserName" parameterType="String" resultMap="bean">
        select * from rechargetotalmoney where userName = #{userName,jdbcType=VARCHAR}
    </select>
    <insert id="insert" parameterType="com.game.db.bean.RechargeTotalMoneyBean" >
        insert into rechargetotalmoney (userId, rechargeTotalMoney,userName, platformAccount)
        values (#{userId,jdbcType=BIGINT}, #{rechargeTotalMoney,jdbcType=INTEGER},#{userName,jdbcType=VARCHAR},#{platformAccount,jdbcType=VARCHAR})
            on duplicate key
        update  rechargeTotalMoney =  rechargeTotalMoney + #{rechargeTotalMoney,jdbcType=BIGINT}

    </insert>
	
    <update id="update" parameterType="com.game.db.bean.RechargeTotalMoneyBean" >
            update rechargetotalmoney set rechargeTotalMoney = #{rechargeTotalMoney,jdbcType=BIGINT} where userId = #{userId,jdbcType=BIGINT}
    </update>
</mapper>
